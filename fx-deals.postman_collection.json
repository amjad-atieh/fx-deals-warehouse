    {
      "name": "Single Deal - Duplicate",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const postRequest = {",
              "  url: pm.collectionVariables.get(\"base_url\") + '/api/deals',",
              "  method: 'POST',",
              "  header: {",
              "    'Content-Type': 'application/json'",
              "  },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      \"dealUniqueId\": \"DUPLICATE-TEST\",",
              "      \"fromCurrencyIsoCode\": \"USD\",",
              "      \"toCurrencyIsoCode\": \"EUR\",",
              "      \"dealTimestamp\": \"2026-04-04T10:00:00\",",
              "      \"dealAmount\": 1250.75",
              "    })",
              "  }",
              "};",
              "",
              "pm.sendRequest(postRequest, function (err, res) {",
              "    if (err) {",
              "        console.log(\"Pre-request deal creation failed:\", err);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 409 Conflict\", function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "pm.test(\"Response status = 'DUPLICATE'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"DUPLICATE\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dealUniqueId\": \"DUPLICATE-TEST\",\n  \"fromCurrencyIsoCode\": \"USD\",\n  \"toCurrencyIsoCode\": \"EUR\",\n  \"dealTimestamp\": \"2026-04-04T10:00:00\",\n  \"dealAmount\": 1250.75\n}"
        },
