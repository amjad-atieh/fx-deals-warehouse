{
  "info": {
    "name": "FX Deals API Test Collection",
    "description": "Complete Postman collection for testing the FX Deals API including field validation, duplicate handling, and batch imports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
