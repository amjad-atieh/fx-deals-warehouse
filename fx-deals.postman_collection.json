  "item": [
    {
      "name": "Single Deal - Valid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response body has status = 'SAVED'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"SAVED\");",
              "});",
              "",
              "pm.test(\"Response body has message containing 'success'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message.toLowerCase()).to.include(\"success\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dealUniqueId\": \"POSTMAN-001\",\n  \"fromCurrencyIsoCode\": \"USD\",\n  \"toCurrencyIsoCode\": \"EUR\",\n  \"dealTimestamp\": \"2026-04-04T10:00:00\",\n  \"dealAmount\": 1250.75\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/deals",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "deals"
          ]
        }
      }
    },
